{
	"$schema": "https://turborepo.org/schema.json",
	"globalPassThroughEnv": ["SB_*", "RUNTIME_ENV", "TZ"],
	"tasks": {
		"start": {
			"dependsOn": ["gql:generate", "db:push", "^build"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": true,
			"persistent": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**"]
		},
		"gql:generate": {},
		"db:pull": {},
		"db:push": {},
		"lint": {}
	}
}
