{
	"name": "nexus",
	"private": true,
	"type": "module",
	"version": "1.0.0",
	"description": "Service responsible for connecting apps to 3rd party services",
	"exports": "./dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"start": "RUNTIME_ENV=production node dist/index.js",
		"dev": "RUNTIME_ENV=development node dist/index.js",
		"build": "rimraf dist/ && tsc && tsc-alias && copyfiles -u 1 src/**/*.graphql dist/",
		"gql:generate": "graphql-codegen-esm"
	},
	"keywords": [],
	"author": "Luís Ferro",
	"license": "MIT",
	"dependencies": {
		"@apollo/utils.keyvadapter": "^4.0.1",
		"@as-integrations/fastify": "^3.1.0",
		"@graphql-tools/load-files": "^7.0.1",
		"@luferro/cache": "workspace:^",
		"@luferro/graphql": "workspace:^",
		"@luferro/scraper": "workspace:^",
		"@luferro/utils": "workspace:^",
		"fastify": "^5.8.4",
		"graphql": "^16.13.2",
		"graphql-tag": "^2.12.6"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^6.3.0",
		"@graphql-codegen/typescript": "^5.0.10",
		"@graphql-codegen/typescript-resolvers": "^5.1.8",
		"@types/node": "^25.6.0",
		"copyfiles": "^2.4.1",
		"rimraf": "^6.1.3",
		"tsc-alias": "^1.8.16",
		"typescript": "^6.0.2"
	}
}
